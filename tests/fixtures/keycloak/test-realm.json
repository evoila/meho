{
  "id": "test-tenant",
  "realm": "test-tenant",
  "displayName": "Test Tenant",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Tenant administrator",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "user",
        "description": "Regular user",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "viewer",
        "description": "Read-only user",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "default-roles-test-tenant",
        "description": "Default roles",
        "composite": true,
        "composites": {
          "realm": ["viewer"]
        },
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "meho-api",
      "name": "MEHO API Backend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "test-secret",
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ]
    },
    {
      "clientId": "meho-frontend",
      "name": "MEHO Frontend",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "rootUrl": "http://localhost:5173",
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "admin@test.local",
      "email": "admin@test.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "default-roles-test-tenant"
      ]
    },
    {
      "username": "user@test.local",
      "email": "user@test.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "default-roles-test-tenant"
      ]
    },
    {
      "username": "viewer@test.local",
      "email": "viewer@test.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer",
        "default-roles-test-tenant"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "description": "User roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "web-origins",
    "acr",
    "profile",
    "roles",
    "email"
  ]
}

