---

---

<section id="how-it-works" class="py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        From question to root cause in seconds
      </h2>
      <p class="text-lg text-body max-w-2xl mx-auto">
        No runbooks. No context switching between 6 dashboards. No 45-minute war rooms.
      </p>
    </div>

    <div class="space-y-20">
      <!-- Step 1: Connect -->
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-4xl font-bold text-meho-purple/20 font-heading">01</span>
            <h3 class="text-2xl font-bold text-headline">Connect your systems</h3>
          </div>
          <p class="text-body leading-relaxed">Add connectors through the MEHO web UI — paste a URL and credentials for Prometheus, Kubernetes, VMware, Loki, ArgoCD, or any of the 15 supported types. Or upload an OpenAPI spec for any REST API.</p>
        </div>
        <div class="flex-1 w-full">
          <!-- MEHO Connectors UI mockup -->
          <div class="rounded-2xl border border-[#27272A] overflow-hidden bg-[#0F0F12] shadow-xl">
            <div class="flex items-center gap-2 px-4 py-3 bg-[#18181B]/60 border-b border-[#27272A]">
              <span class="text-sm font-semibold text-white">Settings</span>
              <span class="text-[#71717A] text-sm">/</span>
              <span class="text-sm text-[#8051B8]">Connectors</span>
            </div>
            <div class="p-4 space-y-2">
              <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-[#18181B] border border-[#27272A]">
                <span class="w-2 h-2 rounded-full bg-[#34D399]"></span>
                <span class="text-xs font-semibold text-[#3B82F6]">Kubernetes</span>
                <span class="text-xs text-[#A1A1AA] flex-1">production-cluster</span>
                <span class="text-[10px] text-[#34D399] bg-[#34D399]/10 px-2 py-0.5 rounded-full">Connected</span>
              </div>
              <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-[#18181B] border border-[#27272A]">
                <span class="w-2 h-2 rounded-full bg-[#34D399]"></span>
                <span class="text-xs font-semibold text-[#E6522C]">Prometheus</span>
                <span class="text-xs text-[#A1A1AA] flex-1">prod-prometheus</span>
                <span class="text-[10px] text-[#34D399] bg-[#34D399]/10 px-2 py-0.5 rounded-full">Connected</span>
              </div>
              <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-[#18181B] border border-[#27272A]">
                <span class="w-2 h-2 rounded-full bg-[#34D399]"></span>
                <span class="text-xs font-semibold text-[#10B981]">VMware</span>
                <span class="text-xs text-[#A1A1AA] flex-1">vcenter-prod</span>
                <span class="text-[10px] text-[#34D399] bg-[#34D399]/10 px-2 py-0.5 rounded-full">Connected</span>
              </div>
              <div class="flex items-center gap-3 px-4 py-3 rounded-xl bg-[#18181B] border border-[#27272A]">
                <span class="w-2 h-2 rounded-full bg-[#34D399]"></span>
                <span class="text-xs font-semibold text-[#F9A825]">Loki</span>
                <span class="text-xs text-[#A1A1AA] flex-1">prod-loki</span>
                <span class="text-[10px] text-[#34D399] bg-[#34D399]/10 px-2 py-0.5 rounded-full">Connected</span>
              </div>
              <div class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-dashed border-[#3F3F46] text-[#71717A] text-xs hover:border-[#8051B8] hover:text-[#8051B8] transition-colors cursor-pointer">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                Add Connector
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Ask -->
      <div class="flex flex-col lg:flex-row-reverse gap-12 items-center">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-4xl font-bold text-meho-purple/20 font-heading">02</span>
            <h3 class="text-2xl font-bold text-headline">Ask a question</h3>
          </div>
          <p class="text-body leading-relaxed">Type a question in plain English. MEHO's orchestrator identifies relevant connectors, dispatches parallel specialist agents, and builds a cross-system investigation graph — all visible in real-time.</p>
        </div>
        <div class="flex-1 w-full">
          <!-- MEHO Investigation Progress mockup -->
          <div class="rounded-2xl border border-[#27272A] overflow-hidden bg-[#0F0F12] shadow-xl">
            <div class="px-4 py-3 bg-[#18181B]/60 border-b border-[#27272A] flex items-center gap-2">
              <svg class="w-4 h-4 text-[#8051B8] animate-spin" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              <span class="text-sm font-semibold text-white">Investigation in Progress</span>
              <span class="text-xs text-[#71717A] ml-auto">4 agents dispatched</span>
            </div>
            <div class="p-4 space-y-2">
              <div class="px-4 py-3 rounded-xl border border-[#27272A] bg-[#18181B]">
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-[#34D399]"></span>
                  <span class="text-xs font-semibold text-[#34D399]">Kubernetes</span>
                  <span class="text-[10px] text-[#71717A]">3 iterations</span>
                  <span class="text-[10px] text-[#71717A] ml-auto">2.1s</span>
                </div>
                <div class="pl-4 border-l border-[#27272A] space-y-1">
                  <p class="text-[10px] text-[#71717A]">list_pods namespace=checkout</p>
                  <p class="text-[10px] text-[#71717A]">describe_pod checkout-7f8b9c-xk2p4</p>
                  <p class="text-[10px] text-[#A1A1AA]">Found: 3 OOMKilled restarts, memory at limit</p>
                </div>
              </div>
              <div class="px-4 py-3 rounded-xl border border-[#27272A] bg-[#18181B]">
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-[#34D399]"></span>
                  <span class="text-xs font-semibold text-[#E6522C]">Prometheus</span>
                  <span class="text-[10px] text-[#71717A]">2 iterations</span>
                  <span class="text-[10px] text-[#71717A] ml-auto">1.2s</span>
                </div>
                <div class="pl-4 border-l border-[#27272A] space-y-1">
                  <p class="text-[10px] text-[#71717A]">query_red_metrics service=checkout-svc</p>
                  <p class="text-[10px] text-[#A1A1AA]">Found: p99 4.2s (normal 200ms), error rate 12%</p>
                </div>
              </div>
              <div class="px-4 py-3 rounded-xl border border-cyan-400/20 bg-cyan-900/10">
                <div class="flex items-center gap-2">
                  <svg class="w-3 h-3 text-cyan-400 animate-spin" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                  <span class="text-xs font-semibold text-cyan-400">VMware</span>
                  <span class="text-[10px] text-[#71717A]">running...</span>
                  <span class="text-[10px] text-[#71717A] ml-auto">1.8s</span>
                </div>
              </div>
              <div class="px-4 py-3 rounded-xl border border-[#27272A] bg-[#18181B]">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-[#71717A]"></span>
                  <span class="text-xs font-semibold text-[#71717A]">Loki</span>
                  <span class="text-[10px] text-[#71717A]">pending</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Root Cause -->
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-4xl font-bold text-meho-purple/20 font-heading">03</span>
            <h3 class="text-2xl font-bold text-headline">Get the root cause</h3>
          </div>
          <p class="text-body leading-relaxed">MEHO synthesizes findings from every system into a unified diagnosis with evidence, confidence levels, and recommended actions. Every query it made is visible and auditable.</p>
        </div>
        <div class="flex-1 w-full">
          <!-- MEHO Synthesis Result mockup -->
          <div class="rounded-2xl border border-[#27272A] overflow-hidden bg-[#0F0F12] shadow-xl">
            <div class="px-4 py-3 bg-[#18181B]/60 border-b border-[#27272A] flex items-center gap-2">
              <svg class="w-4 h-4 text-[#34D399]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-sm font-semibold text-white">Investigation Complete</span>
              <span class="text-xs text-[#71717A] ml-auto">4 systems &middot; 57.7s</span>
            </div>
            <div class="p-4 space-y-3">
              <!-- Synthesis -->
              <div class="px-4 py-3 rounded-xl bg-[#18181B] border border-[#27272A]">
                <p class="text-xs font-semibold text-[#FAFAFA] mb-2">Diagnosis</p>
                <p class="text-xs text-[#A1A1AA] leading-relaxed">ESXi host <span class="text-white font-medium">esxi-prod-03</span> memory utilization hit 92%, triggering memory ballooning on node-7 VM. Kubernetes pod <span class="text-white font-medium">checkout-7f8b9c-xk2p4</span> exceeded its 512Mi limit and entered OOMKill loop. Remaining pods overloaded, saturating the connection pool (20/20 active, 47 pending), causing p99 latency to spike from 200ms to 4.2s.</p>
              </div>
              <!-- Evidence connectors -->
              <div class="flex gap-2 flex-wrap">
                <span class="px-2.5 py-1 rounded-lg text-[10px] font-semibold bg-[#E6522C]/10 text-[#E6522C] border border-[#E6522C]/20">Prometheus</span>
                <span class="px-2.5 py-1 rounded-lg text-[10px] font-semibold bg-[#3B82F6]/10 text-[#3B82F6] border border-[#3B82F6]/20">Kubernetes</span>
                <span class="px-2.5 py-1 rounded-lg text-[10px] font-semibold bg-[#10B981]/10 text-[#10B981] border border-[#10B981]/20">VMware</span>
                <span class="px-2.5 py-1 rounded-lg text-[10px] font-semibold bg-[#F9A825]/10 text-[#F9A825] border border-[#F9A825]/20">Loki</span>
              </div>
              <!-- Recommendations -->
              <div class="px-4 py-3 rounded-xl bg-[#8051B8]/5 border border-[#8051B8]/20">
                <p class="text-xs font-semibold text-[#8051B8] mb-1.5">Recommended Actions</p>
                <ul class="text-xs text-[#A1A1AA] space-y-1">
                  <li class="flex items-start gap-2"><span class="text-[#8051B8] mt-0.5">1.</span> Increase checkout-svc memory limit to 1Gi</li>
                  <li class="flex items-start gap-2"><span class="text-[#8051B8] mt-0.5">2.</span> Investigate memory overcommit on esxi-prod-03</li>
                  <li class="flex items-start gap-2"><span class="text-[#8051B8] mt-0.5">3.</span> Review recent deployment (PR #847 added unbounded cache)</li>
                </ul>
              </div>
              <!-- Follow-up chips -->
              <div class="flex gap-2 flex-wrap">
                <span class="px-3 py-1 text-[10px] rounded-full border border-[#8051B8]/30 text-[#8051B8]/80">Scale checkout-svc to 1Gi</span>
                <span class="px-3 py-1 text-[10px] rounded-full border border-[#8051B8]/30 text-[#8051B8]/80">Show topology graph</span>
                <span class="px-3 py-1 text-[10px] rounded-full border border-[#8051B8]/30 text-[#8051B8]/80">Check other hosts</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
