# =============================================================================
# Private companion repo content — must NEVER land in public history.
# Patterns intentionally have NO trailing slash so they match both real
# directories AND symlinks-to-directories. The meho-init script in
# evoila-bosnia/meho-internal creates `.claude` as a symlink into the
# private repo; with a trailing-slash pattern, gitignore wouldn't catch
# the symlink and the symlinked content could leak into public history.
# =============================================================================
.claude
.planning
.cursor
.vscode
CLAUDE.md

# =============================================================================
# Secrets / env
# =============================================================================
.env
.env.*
!.env.example
.envrc
.envrc.local
*.local.*
*.pem
*.key
*.crt
secrets/
credentials/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage/
htmlcov/
*.egg-info/
.venv/
venv/

# =============================================================================
# JavaScript / Frontend
# =============================================================================
node_modules/
# ``dist/`` covers every compiled JS/CSS output tree, including the operator-
# console Tailwind 4 bundle the backend Dockerfile produces at
# ``backend/src/meho_backplane/ui/static/dist/tailwind.css`` (Initiative #337,
# Task #863) -- the path was previously held only by the catch-all rule;
# explicit comment landed alongside the chassis so the intent is grep-able.
dist/
.next/
.astro/

# =============================================================================
# Build / artifacts
# =============================================================================
build/
target/
*.log

# =============================================================================
# Go (CLI module under cli/)
# =============================================================================
cli/bin/
cli/dist/
cli/coverage.txt
cli/*.out

# =============================================================================
# OS / editor
# =============================================================================
.DS_Store
*.swp
*.swo
*.bak
*.orig
.idea/
*.code-workspace

# =============================================================================
# Docker / runtime data
# =============================================================================
*.pid
*.sock
data/
postgres-data/
