# ============================================================================
# MEHO.X Environment Configuration
# ============================================================================
# Copy to .env and fill in your values:
#   cp env.example .env
#
# Required vars are uncommented. Optional vars with good docker-compose
# defaults are commented out -- uncomment only if you need to override.
#
# For connector credentials (Proxmox, GCP, K8s), see .env.connectors.example
# ============================================================================

# ============================================================================
# LLM Provider (at least one required for AI features)
# ============================================================================
# Default provider: Anthropic Claude. Set MEHO_LLM_PROVIDER to switch.
# Values: anthropic (default), openai, ollama
# MEHO_LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: only needed if using Voyage AI embeddings instead of local TEI
# VOYAGE_API_KEY=

# Required for production. Community default used if unset.
CREDENTIAL_ENCRYPTION_KEY=your-secret-key-at-least-32-characters-long

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
# Defaults work with docker-compose -- only override for external DB.
# The compose file sets POSTGRES_USER=meho, POSTGRES_PASSWORD=password,
# POSTGRES_DB=meho and wires DATABASE_URL for the meho service.

# POSTGRES_USER=meho
# POSTGRES_PASSWORD=password
# POSTGRES_DB=meho
# DATABASE_URL=postgresql+asyncpg://meho:password@postgres:5432/meho

# ============================================================================
# Redis
# ============================================================================
# Default redis://redis:6379/0 is set in docker-compose.

# REDIS_URL=redis://redis:6379/0

# ============================================================================
# LLM Models (Anthropic)
# ============================================================================
# Two-tier model configuration: Sonnet 4.6 for reasoning,
# Haiku 4.5 for utility tasks. All models use PydanticAI format.
#
# These defaults match docker-compose -- override here to change globally,
# or set per-deployment in your .env file.

# Reasoning (Sonnet 4.6)
LLM_MODEL=anthropic:claude-sonnet-4-6
STREAMING_AGENT_MODEL=anthropic:claude-sonnet-4-6
PLANNER_MODEL=anthropic:claude-sonnet-4-6
EXECUTOR_MODEL=anthropic:claude-sonnet-4-6
INTERPRETER_MODEL=anthropic:claude-sonnet-4-6

# Utility tasks (Haiku 4.5)
CLASSIFIER_MODEL=anthropic:claude-haiku-4-6
DATA_EXTRACTOR_MODEL=anthropic:claude-haiku-4-6
WORKFLOW_BUILDER_MODEL=anthropic:claude-haiku-4-6
TRANSFORM_GENERATION_MODEL=anthropic:claude-haiku-4-6
WORKFLOW_LLM_REPORT_MODEL=anthropic:claude-haiku-4-6

# Niche models (uncomment to override Pydantic defaults)
# SKILL_GENERATION_MODEL=anthropic:claude-sonnet-4-6
# MEMORY_EXTRACTION_MODEL=anthropic:claude-sonnet-4-6

# LLM Inference Settings
# LLM_INFERENCE_TIMEOUT=120.0

# Embeddings (Voyage AI)
EMBEDDING_MODEL=voyage-4-large

# ============================================================================
# Keycloak (Identity Provider)
# ============================================================================
# Keycloak runs in Docker on port 8080. These defaults work for local dev.

KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_ID=meho-api

# Frontend Keycloak settings (used by React app / Vite build)
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=meho-community  # Default for community. Override for enterprise.
# VITE_KEYCLOAK_URL=http://localhost:8080
# VITE_KEYCLOAK_REALM=example-tenant
# VITE_KEYCLOAK_CLIENT_ID=meho-frontend

# ============================================================================
# Object Storage (MinIO / S3-compatible)
# ============================================================================
# Defaults work with the bundled MinIO container.

# OBJECT_STORAGE_BUCKET=meho-dev-data
# OBJECT_STORAGE_ENDPOINT=http://minio:9000
# OBJECT_STORAGE_ACCESS_KEY=minioadmin
# OBJECT_STORAGE_SECRET_KEY=minioadmin
# OBJECT_STORAGE_USE_SSL=false

# ============================================================================
# Observability (OpenTelemetry + Seq)
# ============================================================================
# Local Seq UI: http://localhost:5341

OTEL_SERVICE_NAME=meho
OTEL_EXPORTER_OTLP_ENDPOINT=http://seq:80/ingest/otlp
OTEL_CONSOLE=true
MEHO_LOG_LEVEL=INFO

# Trace detail level: full (dev), truncated, summary (production)
# OTEL_TRACE_LEVEL=full
# OTEL_MAX_BODY_SIZE=10240

# ============================================================================
# Knowledge Ingestion Safety
# ============================================================================
# Memory limit for Docling document conversion subprocess.
# Linux only -- macOS has no RLIMIT_AS support; the OS kills on OOM instead.
# INGESTION_MEMORY_LIMIT_MB=8192

# Maximum upload file size. Files exceeding this are rejected before processing.
# INGESTION_MAX_FILE_SIZE_MB=200

# Pages per Docling batch. Large PDFs are split into batches to limit peak memory.
# INGESTION_PAGE_BATCH_SIZE=50

# Enable OCR for scanned PDFs. Disabled by default (saves ~500MB memory).
# Text-native PDFs extract text without OCR -- no quality loss.
# INGESTION_OCR_ENABLED=false

# ============================================================================
# App Settings
# ============================================================================

APP_ENVIRONMENT=dev
CORS_ORIGINS=["http://localhost:5173"]
# FRONTEND_API_URL=http://localhost:8000

# ============================================================================
# Feature Flags
# ============================================================================
# All default to true. Uncomment to disable.

# ENABLE_RATE_LIMITING=true
# ENABLE_MEMORY_EXTRACTION=true
# ENABLE_TRANSCRIPT_PERSISTENCE=true
# ENABLE_DETAILED_EVENTS=true
# ENABLE_OBSERVABILITY_API=true

# Orchestrator tuning (uncomment to override config.yaml defaults)
# ORCHESTRATOR_MAX_ITERATIONS=3
# ORCHESTRATOR_AGENT_TIMEOUT=30.0
# ORCHESTRATOR_TOTAL_TIMEOUT=120.0

# ============================================================================
# Module Feature Flags (MEHO_FEATURE_*)
# ============================================================================
# These control which optional modules are loaded at startup.
# All default to true. Set to false to disable a module.
# Disabling a module removes its API routes and background tasks.
# See: docs/configuration/feature-flags.md for details.

# MEHO_FEATURE_KNOWLEDGE=true        # Knowledge base: document ingestion, embedding, search
# MEHO_FEATURE_TOPOLOGY=true         # Topology discovery, entity graph, cross-system resolution
# MEHO_FEATURE_SCHEDULED_TASKS=true  # Cron-based scheduled task execution
# MEHO_FEATURE_EVENTS=true           # Event-driven triggers (webhooks, scheduled, external)
# MEHO_FEATURE_MEMORY=true           # Operator memory extraction and injection
# MEHO_FEATURE_SLACK=true            # Slack connector and bot (/meho slash command)
# MEHO_FEATURE_NETWORK_DIAGNOSTICS=true  # Built-in SRE tools (dns_resolve, tcp_probe, http_probe, tls_check)
# MEHO_FEATURE_USE_DOCLING=true          # Document ingestion backend: true=Docling (GPU/PyTorch), false=lightweight (CPU-only)
# MEHO_FEATURE_EPHEMERAL_INGESTION=false # Offload large PDFs to ephemeral cloud workers (requires backend config)

APPROVAL_EXPIRY_MINUTES=1440  # 24 hours