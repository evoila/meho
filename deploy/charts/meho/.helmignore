# Patterns to ignore when building a chart package (`helm package`).
# Standard exclusions plus repo-specific noise.
.DS_Store
# Common VCS files
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# CI / agent state
.claude/
.github/
.venv/
node_modules/
