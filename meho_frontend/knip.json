{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/main.tsx", "src/App.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/test/**",
    "src/**/*.test.{ts,tsx}",
    "src/**/*.spec.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "autoprefixer",
    "@tailwindcss/postcss"
  ],
  "ignoreBinaries": ["playwright"],
  "vite": {
    "config": ["vite.config.ts"]
  },
  "vitest": {
    "config": ["vite.config.ts"]
  }
}
