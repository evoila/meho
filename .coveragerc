[run]
source = 
    meho_app

omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */venv/*
    */alembic/*
    */.venv/*
    */site-packages/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    class .*\bProtocol\):
    @overload

precision = 2
show_missing = True
skip_covered = False

[html]
directory = htmlcov

