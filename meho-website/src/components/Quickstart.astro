---

---

<section id="quickstart" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Running in 5 minutes
      </h2>
      <p class="text-lg text-body max-w-2xl mx-auto">
        Docker Compose. That's it.
      </p>
    </div>

    <div class="rounded-xl border border-border overflow-hidden bg-[#0F0F12] shadow-2xl">
      <div class="flex items-center gap-2 px-4 py-3 bg-[#18181B] border-b border-[#27272A]">
        <div class="w-3 h-3 rounded-full bg-[#EF4444]"></div>
        <div class="w-3 h-3 rounded-full bg-[#FBBF24]"></div>
        <div class="w-3 h-3 rounded-full bg-[#34D399]"></div>
        <span class="ml-3 text-xs text-[#71717A] font-mono">terminal</span>
      </div>
      <div class="p-6 font-mono text-sm leading-loose">
        <p><span class="text-[#71717A]"># Clone and start</span></p>
        <p><span class="text-evoila-green">$</span> <span class="text-white">git clone https://github.com/evoila/meho.git</span></p>
        <p><span class="text-evoila-green">$</span> <span class="text-white">cd meho</span></p>
        <p><span class="text-evoila-green">$</span> <span class="text-white">cp env.example .env</span></p>
        <p><span class="text-evoila-green">$</span> <span class="text-white">docker compose up -d</span></p>
        <p class="mt-4"><span class="text-[#71717A]"># Open the UI</span></p>
        <p><span class="text-evoila-green">$</span> <span class="text-white">open http://localhost:5173</span></p>
        <p class="mt-4"><span class="text-meho-purple-light">Ready.</span> <span class="text-[#A1A1AA]">Connect your first system at</span> <span class="text-evoila-light-blue">Settings → Connectors</span></p>
      </div>
    </div>
  </div>
</section>
