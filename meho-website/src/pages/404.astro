---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — MEHO.ai">
  <Navbar />
  <main class="pt-32 pb-24 px-6 text-center min-h-[60vh] flex flex-col items-center justify-center">
    <h1 class="text-6xl font-bold text-headline mb-4">404</h1>
    <p class="text-xl text-body mb-8">This page doesn't exist. Maybe MEHO can investigate?</p>
    <div class="flex gap-4">
      <a href="/" class="px-6 py-3 rounded-lg bg-meho-purple text-white font-semibold hover:bg-meho-purple-light transition-colors">
        Back to home
      </a>
      <a href="https://github.com/evoila/meho" target="_blank" rel="noopener" class="px-6 py-3 rounded-lg border-2 border-headline text-headline font-semibold hover:bg-headline hover:text-white transition-colors">
        Star on GitHub
      </a>
    </div>
  </main>
  <Footer />
</Layout>
