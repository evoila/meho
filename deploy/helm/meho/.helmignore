# Patterns excluded when packaging this chart with `helm package`.
# Same syntax as .gitignore. Standard helm create pattern, plus a
# few MEHO-specific entries.

# OS / editor cruft
.DS_Store
*.swp
*.swo
*.tmp
*.bak
*.orig
*~
.idea/
.vscode/
*.tmproj

# VCS metadata
.git/
.gitignore
.bzr/
.hg/
.hgignore
.svn/

# Helm packaging output: do NOT add `*.tgz` here. The default
# `helm create` skeleton ships that pattern, but it filters out the
# subchart archives `helm dependency update` writes to `charts/`,
# breaking `helm template` with "found in Chart.yaml, but missing in
# charts/ directory". Helm 4 enforces this strictly. The packaged
# chart this directory itself produces lives outside the chart tree
# (e.g. in CI artifacts) and never needs an .helmignore entry.

# Repository CI / contributor metadata that has no role at install time
.github/
.githooks/
OWNERS
OWNERS_ALIASES

# In-tree tests and fixtures (none today; pre-empted for future
# CI smoke-test layout)
tests/
ci/
