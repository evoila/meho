# =============================================================================
# MEHO Connector Credentials (for seed script only)
# =============================================================================
#
# NOTE: These vars are used ONLY by scripts/seed-connectors.sh to create
# connectors via the API. They are NOT read by the running application.
# Connectors are configured through the UI or the seed script.
#
# Usage:
#   cp .env.connectors.example .env.connectors
#   # Edit .env.connectors with your credentials
#   ./scripts/seed-connectors.sh
#
# =============================================================================

# =============================================================================
# MEHO Authentication
# =============================================================================
# Option 1: Use existing auth token
# MEHO_AUTH_TOKEN=your-jwt-token-here

# Option 2: Login credentials (will authenticate and get token)
MEHO_USERNAME=admin@meho.local
MEHO_PASSWORD=your-password-here

# API Base URL (optional, defaults to localhost:8000)
# MEHO_API_URL=http://localhost:8000

# =============================================================================
# PROXMOX ON-PREM DATACENTER
# =============================================================================
# Name and description for the connector
PROXMOX_NAME="Proxmox On-Prem"
PROXMOX_DESCRIPTION="On-premise Proxmox VE datacenter"

# Proxmox host (required) - IP or hostname of your Proxmox server
PROXMOX_HOST=10.5.27.1
PROXMOX_PORT=8006
PROXMOX_SKIP_TLS=true

# Authentication Option 1: API Token (recommended)
# Create via: Datacenter > Permissions > API Tokens
# Token ID format: user@realm!tokenname (e.g., root@pam!meho)
PROXMOX_API_TOKEN_ID=root@pam!meho
PROXMOX_API_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Authentication Option 2: Username/Password (less secure)
# PROXMOX_USERNAME=root@pam
# PROXMOX_PASSWORD=your-password

# =============================================================================
# GOOGLE CLOUD PLATFORM (GCP)
# =============================================================================
# Name and description for the connector
GCP_NAME="GCP Production"
GCP_DESCRIPTION="Google Cloud Platform production environment"

# GCP Project ID (required)
GCP_PROJECT_ID=your-gcp-project-id

# Default region/zone for resources
GCP_DEFAULT_REGION=europe-west3
GCP_DEFAULT_ZONE=europe-west3-a

# Service Account JSON - Option 1: Path to file
# Download from: GCP Console > IAM > Service Accounts > Keys > Add Key > JSON
GCP_SERVICE_ACCOUNT_FILE=/path/to/your-service-account.json

# Service Account JSON - Option 2: Inline JSON (use when file path isn't convenient)
# GCP_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"..."}'

# =============================================================================
# KUBERNETES ON PROXMOX
# =============================================================================
# Name and description for the connector
K8S_PROXMOX_NAME="Kubernetes (Proxmox)"
K8S_PROXMOX_DESCRIPTION="Kubernetes cluster running on Proxmox VE"

# Kubernetes API server URL (required)
# Get from: kubectl cluster-info
K8S_PROXMOX_SERVER_URL=https://10.5.27.3:6443

# Service Account Token (required)
# Create a long-lived token:
#   kubectl create serviceaccount meho-sa -n default
#   kubectl create clusterrolebinding meho-sa-binding --clusterrole=cluster-admin --serviceaccount=default:meho-sa
#   kubectl create token meho-sa -n default --duration=8760h
K8S_PROXMOX_TOKEN=eyJhbGciOiJSUzI1NiIsImtpZCI6I...

# TLS Verification
K8S_PROXMOX_SKIP_TLS=true

# CA Certificate (optional, recommended for production)
# Option 1: Base64 encoded CA cert
# K8S_PROXMOX_CA_CERT=LS0tLS1CRUdJTi...

# Option 2: Path to CA cert file
# K8S_PROXMOX_CA_CERT_FILE=/path/to/ca.crt

# =============================================================================
# KUBERNETES ON GCP (GKE)
# =============================================================================
# Name and description for the connector
K8S_GCP_NAME="Kubernetes (GCP)"
K8S_GCP_DESCRIPTION="GKE cluster on Google Cloud Platform"

# Kubernetes API server URL (required)
# Get from: gcloud container clusters describe <cluster-name> --zone <zone> --format="get(endpoint)"
K8S_GCP_SERVER_URL=https://34.xxx.xxx.xxx

# Service Account Token (required)
# For GKE, you can create a service account token similar to above, or use:
#   gcloud container clusters get-credentials <cluster-name> --zone <zone>
#   kubectl create token meho-sa -n default --duration=8760h
K8S_GCP_TOKEN=eyJhbGciOiJSUzI1NiIsImtpZCI6I...

# TLS Verification (GKE usually has valid certs, so false is OK)
K8S_GCP_SKIP_TLS=false

# CA Certificate (optional)
# K8S_GCP_CA_CERT=LS0tLS1CRUdJTi...
# K8S_GCP_CA_CERT_FILE=/path/to/gke-ca.crt

# =============================================================================
# AMAZON WEB SERVICES (AWS)
# =============================================================================
# Name and description for the connector
AWS_NAME="AWS Production"
AWS_DESCRIPTION="Amazon Web Services production account"

# AWS Access Key (required)
# Create via: IAM > Users > Security credentials > Access keys
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Default region (required)
# See: https://docs.aws.amazon.com/general/latest/gr/rande.html
AWS_DEFAULT_REGION=us-east-1

# Recommended IAM policy: ReadOnlyAccess (or custom policy per service)
# For write operations, add specific service permissions (e.g., ec2:StartInstances)

# =============================================================================
# MICROSOFT AZURE
# =============================================================================
# Name and description for the connector
AZURE_NAME="Azure Production"
AZURE_DESCRIPTION="Microsoft Azure production subscription"

# Subscription ID (required, config field)
# Found in: Azure Portal > Subscriptions > Overview
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Resource group filter (optional, config field)
# Limit operations to a specific resource group
# AZURE_RESOURCE_GROUP_FILTER=my-resource-group

# App registration credentials (required)
# Create via: Azure AD > App registrations > New registration
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret (required)
# Create via: App registration > Certificates & secrets > New client secret
AZURE_CLIENT_SECRET=your-client-secret-here

# Assign Reader role on the subscription for read-only access:
#   az role assignment create --assignee <client-id> --role Reader --scope /subscriptions/<sub-id>

# =============================================================================
# MCP SERVER (External)
# =============================================================================
# Name and description for the connector
MCP_NAME="MCP Server"
MCP_DESCRIPTION="External MCP server integration"

# Transport type (required) -- "streamable_http" or "stdio"
MCP_TRANSPORT_TYPE=streamable_http

# Option 1: HTTP transport (use MCP_SERVER_URL)
# URL of the MCP server endpoint
MCP_SERVER_URL=http://localhost:3000/mcp

# Option 2: Stdio transport (use MCP_COMMAND)
# Path to the MCP server binary
# MCP_COMMAND=npx @modelcontextprotocol/server-everything

# API key (optional) -- only needed if MCP server requires authentication
# MCP_API_KEY=your-api-key-here

# Only one of SERVER_URL or COMMAND is needed depending on TRANSPORT_TYPE

# =============================================================================
# SLACK
# =============================================================================
# Name and description for the connector
SLACK_NAME="Slack Workspace"
SLACK_DESCRIPTION="Slack workspace for investigation context"

# Bot token (required)
# Create via: Slack API > Your Apps > OAuth & Permissions > Bot User OAuth Token
# Required bot token scopes: channels:history, channels:read, chat:write, reactions:write, users:read
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# User token (optional, required for search_messages)
# Create via: Slack API > Your Apps > OAuth & Permissions > User Token
# Required user token scope: search:read
# SLACK_USER_TOKEN=xoxp-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# VMWARE NSX MANAGER (optional, for VCF environments)
# =============================================================================
# These are separate from vCenter credentials. Only needed for NSX operations.
# Add these fields to your existing VMware connector configuration.

# NSX Manager hostname or IP (required if using NSX)
VMW_NSX_HOST=nsx-manager.example.com

# NSX Manager credentials (required if using NSX)
# Uses Basic Auth against the NSX Policy API
VMW_NSX_USERNAME=admin
VMW_NSX_PASSWORD=your-nsx-password

# =============================================================================
# VMWARE SDDC MANAGER (optional, for VCF environments)
# =============================================================================
# These are separate from vCenter credentials. Only needed for SDDC operations.
# Add these fields to your existing VMware connector configuration.

# SDDC Manager hostname or IP (required if using SDDC Manager)
VMW_SDDC_HOST=sddc-manager.example.com

# SDDC Manager credentials (required if using SDDC Manager)
# Uses Bearer Token authentication (token obtained automatically)
VMW_SDDC_USERNAME=admin@local
VMW_SDDC_PASSWORD=your-sddc-password
